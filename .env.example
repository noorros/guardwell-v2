# GuardWell v2 — Environment variables
# Copy to .env and fill in values. NEVER commit .env.

# ── Database (Cloud SQL via Cloud SQL Proxy in dev) ──────────────────────────
# Local dev: ./cloud-sql-proxy guardwell-prod:us-central1:guardwell-v2-db --port 5433
DATABASE_URL="postgresql://USER:PASS@127.0.0.1:5433/guardwell_v2?schema=public"

# ── Firebase Auth ────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side) — JSON-stringified service account
# OR set FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY individually
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Stripe (single tier) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# ── Anthropic (LLM) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: route to Claude observability (Langfuse/Helicone) when configured
LLM_OPS_PROVIDER=
LLM_OPS_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="GuardWell <noreply@gwcomp.com>"
EMAIL_REPLY_TO=support@gwcomp.com

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_SECRET=

# ── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://v2.app.gwcomp.com
NEXT_PUBLIC_MARKETING_URL=https://gwcomp.com

# ── Build / runtime flags ────────────────────────────────────────────────────
# Set to "off" to disable nonce-based CSP (debugging only)
CSP_NONCE_MODE=on

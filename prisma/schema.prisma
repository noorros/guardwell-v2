// GuardWell v2 — Prisma schema
//
// Foundational tables only. Domain modules (training, incidents, etc.) get
// added as they're built per the weeks-1–2 implementation plan.
//
// Architecture references:
//   docs/adr/0001-event-sourcing.md       — EventLog is the source of truth
//   docs/adr/0002-regulations-operations-matrix.md — schema models the matrix
//   docs/adr/0003-llm-ops.md              — LlmCall observability
//   docs/adr/0004-modules-as-data.md      — Regulatory* tables are data, not code
//   docs/adr/0005-design-system.md        — color/score thresholds live here

generator client {
  provider      = "prisma-client-js"
  // native for local dev; debian-openssl-3.0.x for node:20-slim in Cloud Run.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// Identity
// ────────────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  firebaseUid     String    @unique
  email           String    @unique
  firstName       String?
  lastName        String?
  emailVerified   Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  // Internal admin flag — gates /admin surface (customer health, manual
  // subscription overrides, etc). Toggled manually via SQL or seeding;
  // no UI to grant. Defaults to false so a forgotten flag never opens
  // the admin surface to a real customer.
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  practiceUsers          PracticeUser[]
  emittedEvents          EventLog[]              @relation("EventActor")
  legalAcceptances       LegalAcceptance[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  policyAcknowledgments  PolicyAcknowledgment[]
  trainingCompletions    TrainingCompletion[]

  @@index([firebaseUid])
  @@index([email])
}

model LegalAcceptance {
  id           String   @id @default(cuid())
  userId       String
  documentType String // TOS, PRIVACY, PLATFORM_DISCLAIMER, BAA, DPA
  version      String
  acceptedAt   DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, documentType])
}

// ────────────────────────────────────────────────────────────────────────────
// Tenancy — Practice + PracticeUser (per ADR-0001 multi-tenant by practiceId)
// ────────────────────────────────────────────────────────────────────────────

model Practice {
  id               String    @id @default(cuid())
  name             String
  primaryState     String // ISO state code, e.g. "AZ"
  operatingStates  String[]  @default([]) // additional states for multi-state practices
  // IANA timezone (e.g. "America/Phoenix"). null = pre-backfill row;
  // formatPracticeDate falls back to UTC. Default-derived from
  // primaryState at create time and via scripts/backfill-practice-timezone.ts.
  timezone         String?
  specialty        String?
  npiNumber        String?
  ehrSystem        String?
  phone            String?
  addressStreet    String?
  addressSuite     String?
  addressCity      String?
  addressZip       String?
  entityType       String    @default("COVERED_ENTITY") // COVERED_ENTITY | BUSINESS_ASSOCIATE
  providerCount    String    @default("SOLO") // SOLO | SMALL_2_5 | MEDIUM_6_15 | LARGE_16_PLUS
  staffHeadcount   Int?
  setupCompletedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Stripe (single tier)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  // INCOMPLETE = signed up but no Stripe Checkout completed yet (default
  // for new self-serve sign-ups per docs/specs/onboarding-flow.md).
  // TRIALING = Stripe webhook fired checkout.session.completed → 7-day trial.
  // ACTIVE = first invoice paid. PAST_DUE = invoice failed. CANCELED = sub deleted.
  subscriptionStatus   String    @default("INCOMPLETE") // INCOMPLETE | TRIALING | ACTIVE | PAST_DUE | CANCELED
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  // Set when the OWNER completes the 4-step first-run wizard.
  // null = wizard not finished (top-of-dashboard re-prompt fires).
  firstRunCompletedAt  DateTime?

  // Per-practice GCS evidence storage quota in bytes.
  // null = use default (PRACTICE_STORAGE_QUOTA_BYTES env var or 5 GB).
  storageQuotaBytes BigInt?

  // Phase 7: per-category lead-time overrides. Defaults live in
  // src/lib/notifications/leadTimes.ts. Shape:
  //   { credentials: [90, 60, 30, 7], training: [60, 30, 14], ... }
  // Missing keys fall back to the helper's default.
  reminderSettings Json?

  practiceUsers       PracticeUser[]
  practicePolicies    PracticePolicy[]
  trainingCompletions TrainingCompletion[]
  trainingAssignments TrainingAssignment[]
  vendors             Vendor[]
  credentials         Credential[]
  sraAssessments      PracticeSraAssessment[]
  incidents           Incident[]
  invitations         PracticeInvitation[]
  complianceProfile   PracticeComplianceProfile?
  events              EventLog[]
  complianceItems     ComplianceItem[]
  enabledFrameworks   PracticeFramework[]
  llmCalls            LlmCall[]
  scoreSnapshots      ComplianceScoreSnapshot[]
  // PracticeTrackTask rows are accessed via complianceTrack.tasks — no
  // direct back-relation needed since PracticeTrackTask.practiceId
  // references PracticeTrack.practiceId, not Practice.id.
  complianceTrack     PracticeTrack?
  destructionLogs     DestructionLog[]
  techAssets          TechAsset[]
  auditPrepSessions   AuditPrepSession[]
  dripSends           OnboardingDripSent[]
  phishingDrills      PhishingDrill[]
  backupVerifications BackupVerification[]
  allergyCompetencies     AllergyCompetency[]
  allergyQuizAttempts     AllergyQuizAttempt[]
  allergyEquipmentChecks  AllergyEquipmentCheck[]
  allergyDrills           AllergyDrill[]
  evidence                Evidence[]
  deaInventories          DeaInventory[]
  deaOrders               DeaOrderRecord[]
  deaDisposals            DeaDisposalRecord[]
  deaTheftLossReports     DeaTheftLossReport[]
  ceuActivities           CeuActivity[]
  credentialReminders     CredentialReminderConfig[]
  baaRequests             BaaRequest[]
  baaAcceptanceTokens     BaaAcceptanceToken[]
  macraActivityLogs       MacraActivityLog[]
  conversationThreads     ConversationThread[]
  // Audit #21 (HIPAA I-1, 2026-04-30): per-state AG notification rows
  // for multi-state breaches. One row per affected state per breach.
  incidentStateAgNotifications IncidentStateAgNotification[]
  // Phase 4 PR 6 (BYOV): per-(user, course) video watch tracker.
  videoProgress           VideoProgress[]
  // Phase 8: per-practice regulatory alerts. One row per (practice, article)
  // where the article matched at least one of the practice's enabled frameworks.
  regulatoryAlerts        RegulatoryAlert[]

  @@index([primaryState])
  @@index([subscriptionStatus])
  @@index([deletedAt])
}

enum PracticeRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

model PracticeUser {
  id                  String       @id @default(cuid())
  userId              String
  practiceId          String
  role                PracticeRole @default(STAFF)
  // Officer designations (multi-select stored as denormalized booleans)
  isPrivacyOfficer    Boolean      @default(false)
  isSecurityOfficer   Boolean      @default(false)
  isComplianceOfficer Boolean      @default(false)
  isSafetyOfficer     Boolean      @default(false)
  joinedAt            DateTime     @default(now())
  removedAt           DateTime?
  // Cybersecurity emphasis (2026-04-23): per-user MFA enrollment
  // attestation. Captured by an officer (no IdP integration in v2 launch
  // scope), not the user themselves, so it counts as evidence.
  mfaEnrolledAt       DateTime?
  // USP 797 §21 — per-user gate. true = this user compounds allergen
  // extracts and must complete the annual 3-component competency.
  requiresAllergyCompetency      Boolean @default(false)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  credentials Credential[]
  evidenceUploaded           Evidence[]             @relation("EvidenceUploadedBy")
  allergyCompetencies        AllergyCompetency[]    @relation("AllergyCompetencyHolder")
  allergyFingertipAttestations AllergyCompetency[]  @relation("AllergyFingertipAttestor")
  allergyMediaFillAttestations AllergyCompetency[]  @relation("AllergyMediaFillAttestor")
  allergyQuizAttempts        AllergyQuizAttempt[]   @relation("AllergyQuizTaker")
  allergyEquipmentChecks     AllergyEquipmentCheck[] @relation("AllergyCheckPerformedBy")
  allergyDrillsLed           AllergyDrill[]         @relation("AllergyDrillLedBy")

  @@unique([userId, practiceId])
  @@index([practiceId, role])
  @@index([practiceId, removedAt])
  @@index([practiceId, mfaEnrolledAt])
}

// Evidence for POLICY:* requirements. Append-only at the application
// layer — mutations go through appendEventAndApply() per ADR-0001.
// Retiring a policy sets retiredAt instead of deleting.
model PracticePolicy {
  id             String    @id @default(cuid())
  practiceId     String
  policyCode     String // e.g. "HIPAA_PRIVACY_POLICY" — see src/lib/compliance/policies.ts
  content        String?   @db.Text
  version        Int       @default(1)
  adoptedAt      DateTime  @default(now())
  // Set on each annual review attestation. Initially equals adoptedAt;
  // bumped via POLICY_REVIEWED event. Drives the "Review due in N days"
  // reminder + a new HIPAA_POLICIES_REVIEW_CURRENT requirement.
  lastReviewedAt DateTime?
  retiredAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  practice        Practice               @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  versions        PolicyVersion[]
  acknowledgments PolicyAcknowledgment[]
  trainingPrereqs PolicyTrainingPrereq[]

  @@unique([practiceId, policyCode])
  @@index([practiceId, retiredAt])
  @@index([practiceId, lastReviewedAt])
}

// Append-only history of every PracticePolicy state. A new row is
// created on each save (POLICY_CONTENT_UPDATED) BEFORE the PracticePolicy
// row is overwritten — so PolicyVersion holds the prior states, and
// the PracticePolicy row holds the current state. Diff = (current ↔ any
// historical) or (historical ↔ historical). Adoption itself also writes
// a v1 baseline row.
model PolicyVersion {
  id               String   @id @default(cuid())
  practicePolicyId String
  // Sequential version number — matches PracticePolicy.version at the
  // time this snapshot was taken.
  version          Int
  // Body content at this version. Nullable so we can model "policy
  // adopted but no body authored yet" as version 1 with content=null.
  content          String?  @db.Text
  savedByUserId    String?
  savedAt          DateTime @default(now())
  // Free-form change-summary the user can include alongside Save.
  // Empty/null for v1 (initial adoption baseline).
  changeNote       String?  @db.Text

  policy PracticePolicy @relation(fields: [practicePolicyId], references: [id], onDelete: Cascade)

  @@unique([practicePolicyId, version])
  @@index([practicePolicyId, savedAt])
}

// Per-user acknowledgment of a specific PracticePolicy version. v1
// audit-defense feature port (2026-04-24): "Show me proof every
// workforce member read your Privacy Policy" is an OCR auditor's
// first ask. Each acknowledgment captures the user, the policy, the
// version they signed, and the typed signature text. Editing a policy
// (POLICY_CONTENT_UPDATED bumps the version) makes prior acknowledgments
// stale — staff need to re-sign the new version.
//
// The PolicyAcknowledgment.policyVersion column is the canonical
// "what version did this user sign" — we don't reuse PolicyVersion.id
// because PolicyVersion is per-instance + we want to avoid coupling.
model PolicyAcknowledgment {
  id               String   @id @default(cuid())
  practicePolicyId String
  userId           String
  // Snapshot of PracticePolicy.version at signing time. Stale when the
  // current PracticePolicy.version > this value.
  policyVersion    Int
  // Free-form text the user typed when signing — e.g. "I have read and
  // will comply with the HIPAA Privacy Policy." Becomes part of the
  // audit trail.
  signatureText    String   @db.Text
  acknowledgedAt   DateTime @default(now())

  policy PracticePolicy @relation(fields: [practicePolicyId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Allow re-signing each new version: composite unique on (policy,
  // user, version) so v3-acked + v4-acked can both exist.
  @@unique([practicePolicyId, userId, policyVersion])
  @@index([practicePolicyId, acknowledgedAt])
  @@index([userId, acknowledgedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// SRA — HIPAA Security Risk Assessment (45 CFR §164.308(a)(1)(ii)(A))
// ────────────────────────────────────────────────────────────────────────────

enum SraCategory {
  ADMINISTRATIVE
  PHYSICAL
  TECHNICAL
}

enum SraAnswer {
  YES
  NO
  PARTIAL
  NA
}

// Reference data. Seeded via scripts/seed-sra.ts from the v1 question bank.
// ~20 canonical safeguards at launch; expand post-launch.
model SraQuestion {
  id          String      @id @default(cuid())
  code        String      @unique // "ADMIN_RISK_ANALYSIS"
  category    SraCategory
  subcategory String // "Security Management Process"
  title       String
  description String      @db.Text
  guidance    String?     @db.Text // what OCR looks for
  lookFor     String[] // practical checklist items
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  answers PracticeSraAnswer[]

  @@index([category, sortOrder])
}

// Practice-level compliance characteristics. Drives which frameworks
// appear in the sidebar: a practice without an in-house lab has CLIA
// auto-disabled; a practice that doesn't dispense controlled
// substances has DEA auto-disabled; and so on. HIPAA + OSHA + OIG stay
// on for everyone — they're baseline for any healthcare practice.
//
// Filled during /onboarding/compliance-profile right after the
// practice is created. Editable later at /settings/practice.
model PracticeComplianceProfile {
  practiceId                    String   @id
  // Operational characteristics that gate framework applicability.
  hasInHouseLab                 Boolean  @default(false) // → CLIA
  dispensesControlledSubstances Boolean  @default(false) // → DEA
  medicareParticipant           Boolean  @default(true) // → CMS
  billsMedicaid                 Boolean  @default(true) // → CMS (either)
  subjectToMacraMips            Boolean  @default(true) // → MACRA
  sendsAutomatedPatientMessages Boolean  @default(true) // → TCPA
  // Descriptive metadata — not gates today but surfaced in reports.
  specialtyCategory             String? // PRIMARY_CARE | SPECIALTY | DENTAL | BEHAVIORAL | ALLIED | OTHER
  providerCount                 Int?
  // Allergy/immunology specialty practices that compound allergen extracts
  // are subject to USP 797 §21. Toggling true enables the ALLERGY framework
  // via the PRACTICE_PROFILE_UPDATED projection.
  compoundsAllergens            Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

// Per-user notification inbox. One row per user-visible event. Multiple
// delivery channels (email, in-product inbox) write to the same row —
// `sentViaEmailAt` tracks email success separately from `readAt` so the
// inbox and the digest email don't reference different records.
enum NotificationType {
  SRA_DUE
  TRAINING_ASSIGNED
  TRAINING_DUE_SOON
  TRAINING_EXPIRING
  TRAINING_OVERDUE
  TRAINING_ESCALATION
  CREDENTIAL_EXPIRING
  CREDENTIAL_RENEWAL_DUE
  CREDENTIAL_ESCALATION
  CMS_ENROLLMENT_EXPIRING
  VENDOR_BAA_EXPIRING
  INCIDENT_OPEN
  INCIDENT_BREACH_UNRESOLVED
  INCIDENT_BREACH_DEADLINE_APPROACHING
  BREACH_DETERMINATION_DEADLINE_APPROACHING
  POLICY_STALE
  POLICY_REVIEW_DUE
  OSHA_POSTING_REMINDER
  WELCOME
  ALLERGY_DRILL_DUE
  ALLERGY_FRIDGE_OVERDUE
  ALLERGY_KIT_EXPIRING
  ALLERGY_COMPETENCY_DUE
  // Phase 7 additions
  POLICY_ACKNOWLEDGMENT_PENDING
  BAA_SIGNATURE_PENDING
  BAA_EXECUTED
  DEA_BIENNIAL_INVENTORY_DUE
  PHISHING_DRILL_DUE
  BACKUP_VERIFICATION_OVERDUE
  DOCUMENT_DESTRUCTION_OVERDUE
  SUBSCRIPTION_PAST_DUE
  SUBSCRIPTION_CANCELED
  SUBSCRIPTION_BILLING_ISSUE
  SYSTEM_NOTIFICATION
  WEEKLY_DIGEST_AVAILABLE
  REGULATORY_ALERT
  STATE_LAW_UPDATE
  AUDIT_PREP_SESSION_OPENING
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

model Notification {
  id             String               @id @default(cuid())
  practiceId     String
  userId         String
  type           NotificationType
  severity       NotificationSeverity @default(INFO)
  title          String
  body           String               @db.Text
  href           String?
  // "Entity this notification is about" — SRA id, training completion id,
  // vendor id, etc. Used for dedup: running the digest twice in one
  // period shouldn't spam the user with the same alert.
  entityKey      String?
  readAt         DateTime?
  sentViaEmailAt DateTime?
  createdAt      DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, entityKey])
  @@index([userId, readAt, createdAt])
  @@index([practiceId, createdAt])
}

model NotificationPreference {
  userId                String   @id
  digestEnabled         Boolean  @default(true)
  criticalAlertsEnabled Boolean  @default(true)
  emailEnabled          Boolean  @default(true)
  // Phase 7 additions
  cadence               String   @default("DAILY") // INSTANT | DAILY | WEEKLY | NONE
  channels              String[] @default(["EMAIL", "IN_APP"])
  categoryFilters       String[] @default([])
  digestTime            String   @default("08:00")
  digestDay             String   @default("MON")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 7 PR 9 — Resend bounce + complaint suppression list. The
// webhook at /api/webhooks/resend writes here on bounce / complaint
// events; sendEmail() reads here before each Resend call to avoid
// repeatedly sending to known-bad addresses.
model EmailSuppression {
  id           String   @id @default(cuid())
  email        String   @unique
  reason       String   // BOUNCE | COMPLAINT | UNSUBSCRIBE | MANUAL
  resendId     String?  // Svix message id for audit trail
  suppressedAt DateTime @default(now())

  @@index([reason, suppressedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Regulatory intelligence engine (Phase 8)
// ────────────────────────────────────────────────────────────────────────────

// One per ingestion target — RSS feed, atom feed, or scrape config.
// Disabled sources are skipped by the daily ingest cron.
model RegulatorySource {
  id              String                @id @default(cuid())
  name            String                // "HHS OCR Breach Portal"
  url             String                @unique
  feedType        String                // RSS | ATOM | SCRAPE
  isActive        Boolean               @default(true)
  // Optional CSS selector / scrape config for SCRAPE feedType. Null for RSS/ATOM.
  scrapeConfig    Json?
  // Frameworks this source typically covers — preliminary tags applied at
  // ingest, refined per-article by the analyzer. Drives initial fan-out.
  defaultFrameworks String[]            @default([])
  lastIngestedAt  DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  articles        RegulatoryArticle[]

  @@index([isActive, lastIngestedAt])
}

// One per article ingested. URL is unique to dedup across cron runs.
// rawContent is the full article body (truncated to ~50KB to bound
// downstream prompt token cost). summary is what the source feed
// provided (often <500 chars).
model RegulatoryArticle {
  id              String              @id @default(cuid())
  sourceId        String
  title           String
  url             String              @unique
  summary         String?             @db.Text
  rawContent      String?             @db.Text
  publishDate     DateTime?
  ingestedAt      DateTime            @default(now())
  // Set by the analyzer cron after Claude has scored relevance per
  // framework. Null = pending analysis.
  analyzedAt      DateTime?
  // Frameworks Claude judged relevant (relevance >= MED). Drives
  // per-practice fan-out by intersection with PracticeFramework.enabled.
  relevantFrameworks String[]         @default([])

  source          RegulatorySource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  alerts          RegulatoryAlert[]

  @@index([sourceId, ingestedAt])
  @@index([analyzedAt, ingestedAt])
}

// One per (article, practice) where the article matched at least one
// of the practice's enabled frameworks. Created by the analyze cron.
// Notification rows are derived from this in the notify cron.
model RegulatoryAlert {
  id                  String                  @id @default(cuid())
  practiceId          String
  articleId           String
  alertBody           String                  @db.Text  // AI-generated practice-tailored summary
  recommendedActions  String[]                @default([])  // up to 5 short action strings
  severity            String                  // INFO | ADVISORY | URGENT
  matchedFrameworks   String[]                @default([])  // intersection of article + practice frameworks
  sentAt              DateTime?               // null until notify cron fires
  acknowledgedAt      DateTime?
  acknowledgedByUserId String?
  dismissedAt         DateTime?
  dismissedByUserId   String?
  createdAt           DateTime                @default(now())

  practice            Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  article             RegulatoryArticle       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  actions             AlertAction[]

  @@unique([practiceId, articleId])  // one alert per (practice, article)
  @@index([practiceId, dismissedAt, createdAt])
  @@index([practiceId, severity, createdAt])
  // Phase 8 PR 5 — covers the notify cron's global scan
  // (sentAt IS NULL AND dismissedAt IS NULL ORDER BY createdAt ASC).
  // Neither index above leads with sentAt; without this, the scan
  // fully scans the table.
  @@index([sentAt, dismissedAt, createdAt])
}

// Optional follow-up actions added by admins on alert detail pages.
// "Add to my CAP" creates one of these and ALSO creates a CorrectiveAction
// row in Phase 5's CAP register (when Phase 5 ships; until then, AlertAction
// stands alone).
model AlertAction {
  id                String        @id @default(cuid())
  alertId           String
  description       String
  ownerUserId       String?
  dueDate           DateTime?
  completionStatus  String        @default("PENDING")  // PENDING | COMPLETED
  createdAt         DateTime      @default(now())

  alert             RegulatoryAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
}

// Team invitations. An OWNER/ADMIN invites an email with a role; the
// invitation persists until accepted, revoked, or expired. Accept flow
// creates a PracticeUser for the invitee on first sign-in.
model PracticeInvitation {
  id               String       @id @default(cuid())
  practiceId       String
  invitedByUserId  String
  invitedEmail     String
  role             PracticeRole
  token            String       @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  createdAt        DateTime     @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, acceptedAt])
  @@index([invitedEmail])
}

// Incidents — privacy/security/OSHA events that may or may not be breaches.
// A reported incident starts with status=OPEN + isBreach=null (undetermined).
// The breach determination wizard fills the four HIPAA §164.402 "low
// probability of compromise" factors, computes an overall risk score, and
// sets isBreach. Resolution closes the incident loop.
//
// Derivation hooks:
//   HIPAA_BREACH_RESPONSE — composite rule: breach-response POLICY adopted
//     AND no unresolved major breaches.
//   OSHA_300_LOG — wired via INCIDENT:OSHA_RECORDABLE evidence in a later PR.
//   HIPAA_CA_BREACH_NOTIFICATION_72HR — wired via state-overlay derivation
//     in a later PR (notification timestamp ≤ 15 business days from discovery).
enum IncidentType {
  PRIVACY
  SECURITY
  OSHA_RECORDABLE
  NEAR_MISS
  DEA_THEFT_LOSS
  CLIA_QC_FAILURE
  TCPA_COMPLAINT
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  OPEN
  UNDER_INVESTIGATION
  RESOLVED
  CLOSED
}

enum BaaStatus {
  DRAFT       // Practice has uploaded the draft document; no token sent yet
  SENT        // Practice has emailed the vendor a token-protected accept link
  ACKNOWLEDGED // Vendor has opened the accept link (token validated)
  EXECUTED    // Vendor typed signature + agreed; BAA is fully executed
  REJECTED    // Vendor declined the BAA (post-launch v2 feature; modeled now)
  EXPIRED     // baaExpiresAt has passed
  SUPERSEDED  // Replaced by a newer BAA version (post-launch)
}

model Incident {
  id                            String           @id @default(cuid())
  practiceId                    String
  reportedByUserId              String
  title                         String
  description                   String           @db.Text
  type                          IncidentType     @default(PRIVACY)
  severity                      IncidentSeverity @default(LOW)
  status                        IncidentStatus   @default(OPEN)
  // Breach determination state. null = undetermined (wizard not run yet).
  isBreach                      Boolean?
  phiInvolved                   Boolean          @default(false)
  affectedCount                 Int?
  discoveredAt                  DateTime
  reportedAt                    DateTime         @default(now())
  resolvedAt                    DateTime?
  // HIPAA §164.402 four-factor analysis (1-5 each; 1=low risk → 5=high risk)
  factor1Score                  Int?
  factor2Score                  Int?
  factor3Score                  Int?
  factor4Score                  Int?
  overallRiskScore              Int? // composite 0-100 produced by the breach wizard
  breachDeterminedAt            DateTime?
  // HIPAA §164.402 documented breach determination memo. Markdown text
  // entered by the determiner during the wizard; rendered on the breach
  // memo PDF audit response.
  breachDeterminationMemo String? @db.Text
  // HHS Office for Civil Rights notification tracking. ocrNotifiedAt is
  // synonymous with the new INCIDENT_NOTIFIED_HHS event timestamp; the
  // event projection writes here directly so existing readers keep working.
  ocrNotifyRequired             Boolean          @default(false)
  ocrNotifiedAt                 DateTime?
  // Granular post-determination notification tracking. Populated by the
  // INCIDENT_NOTIFIED_AFFECTED_INDIVIDUALS / _MEDIA / _STATE_AG events.
  // null = not yet notified. State-overlay derivation rules (e.g.
  // HIPAA_CA_BREACH_NOTIFICATION_72HR) read these timestamps to decide
  // whether the state-specific notification window was met.
  affectedIndividualsNotifiedAt DateTime?
  mediaNotifiedAt               DateTime?
  stateAgNotifiedAt             DateTime?
  // OSHA recordable fields — only populated when type=OSHA_RECORDABLE.
  oshaBodyPart                  String?
  oshaInjuryNature              String?
  oshaOutcome                   String? // DEATH | DAYS_AWAY | RESTRICTED | OTHER_RECORDABLE | FIRST_AID
  oshaDaysAway                  Int?
  oshaDaysRestricted            Int?
  // 29 CFR §1910.1030 Bloodborne Pathogens Standard requires a sharps
  // injury log distinct from the OSHA 300 log. This field captures the
  // device type (needle / scalpel / lancet / other) so the sharps log
  // can be filtered out of the broader OSHA 300 view post-launch.
  sharpsDeviceType              String?
  // Audit #19 (OSHA B-3 / I-5): the user who was INJURED — distinct from
  // reportedByUserId (the user who clicked Report). §1904.35(b)(2)(v)
  // privacy rules govern the injured employee, NOT the reporter. Form
  // 300/301 PDFs prefer this when set; legacy rows (pre-audit) fall back
  // to reportedByUserId so the inspector view stays populated. Nullable
  // because non-OSHA incident types don't have an injured employee.
  injuredUserId                 String?
  // State breach-notification tracking — populated once the wizard confirms
  // isBreach=true for a practice with a non-federal state in scope.
  patientState                  String?
  // Audit #21 (HIPAA I-1, 2026-04-30): the full set of states whose
  // residents were affected by this breach. Distinct from `patientState`
  // (the primary or single-state case) — when a breach touches residents
  // of multiple states, we must track each state's AG notification
  // deadline separately because deadlines + thresholds vary by state.
  // Empty list = single-state breach (use `patientState`); non-empty
  // list overrides patientState for multi-state notification tracking.
  // The IncidentStateAgNotification join table is the source of truth
  // for per-state deadlines.
  affectedPatientStates         String[]         @default([])
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  practice           Practice             @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deaTheftLossReports DeaTheftLossReport[]
  stateAgNotifications IncidentStateAgNotification[]

  @@index([practiceId, status])
  @@index([practiceId, isBreach])
  @@index([practiceId, discoveredAt])
  @@index([practiceId, injuredUserId])
}

// Audit #21 (HIPAA I-1, 2026-04-30): per-state AG notification tracking
// for multi-state breaches. Each row = one state-specific obligation
// derived at breach-determination time. The single-state case still
// generates one row (the practice's primaryState or `patientState`),
// preserving uniform handling. Replays are idempotent via the
// (incidentId, state) unique constraint.
//
// `deadlineAt` snapshots the per-state HIPAA-overlay window at
// determination time; ongoing changes to the rules in hipaa.ts do NOT
// retroactively shift recorded deadlines (audit-stability: the
// determination memo and the deadline must be reproducible at any
// point in the future).
//
// `notifiedAt` is set when an INCIDENT_NOTIFIED_STATE_AG event with
// a matching stateCode fires. Pre-audit-#21 events without a stateCode
// fall back to updating the matching primary-state row.
model IncidentStateAgNotification {
  id          String   @id @default(cuid())
  practiceId  String
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  state       String
  deadlineAt  DateTime
  notifiedAt  DateTime?
  // Snapshot of `affectedCount` at determination time so the per-state
  // threshold-driven AG-notification rule (e.g. "TX requires AG notice
  // for ≥250 affected") can be replayed without re-deriving from the
  // current Incident.affectedCount.
  thresholdAffectedCount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([incidentId, state])
  @@index([practiceId, state])
  @@index([practiceId, deadlineAt])
}

// Evidence for HIPAA_SRA. One row per completion event. Drafts (isDraft=true)
// persist partial progress across sessions and are promoted to completed
// on SRA_COMPLETED. Only completed (isDraft=false) rows satisfy the HIPAA_SRA
// derivation rule.
model PracticeSraAssessment {
  id                String    @id @default(cuid())
  practiceId        String
  completedByUserId String
  // Null while drafting; set on promotion to completed. Used by
  // hipaaSraRule to count only completed assessments in the last 365 days.
  completedAt       DateTime?
  overallScore      Int       @default(0) // % of questions addressed (YES or NA), 0-100
  addressedCount    Int       @default(0) // count of YES + NA
  totalCount        Int       @default(0) // total questions answered
  // True while the user is still working through the wizard. Flipped to
  // false when SRA_COMPLETED promotes the draft.
  isDraft           Boolean   @default(false)
  // Which wizard step the user left off on (0=administrative, 1=physical,
  // 2=technical). Only meaningful while isDraft=true.
  currentStep       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  practice Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  answers  PracticeSraAnswer[]

  @@index([practiceId, completedAt])
  @@index([practiceId, isDraft])
}

model PracticeSraAnswer {
  id           String    @id @default(cuid())
  assessmentId String
  questionId   String
  answer       SraAnswer
  notes        String?   @db.Text

  assessment PracticeSraAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   SraQuestion           @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
}

// ────────────────────────────────────────────────────────────────────────────
// Credentials — per-provider license/certification tracking (ported from v1)
// ────────────────────────────────────────────────────────────────────────────

enum CredCategory {
  CLINICAL_LICENSE
  DEA_REGISTRATION
  BOARD_CERTIFICATION
  CPR_BLS_ACLS
  VACCINATION
  MALPRACTICE_INSURANCE
  FACILITY_LICENSE
  MEDICARE_MEDICAID
  OSHA_TRAINING
  HIPAA_TRAINING
  BACKGROUND_CHECK
  CUSTOM
}

// DEA controlled-substance schedules per 21 CFR §1308. Schedule I is
// almost never relevant for healthcare (research-only) but listed for
// completeness; II–V are the practical tracking surface.
enum DeaSchedule {
  CI
  CII
  CIIN
  CIII
  CIIIN
  CIV
  CV
}

// Reference data. Seeded from scripts/seed-credentials.ts; read-only.
// Launch ships system-wide types only — per-practice custom types are a
// post-launch feature (tracked in v2-deferred-roadmap.md).
model CredentialType {
  id                String       @id @default(cuid())
  code              String       @unique // "MD_STATE_LICENSE", "DEA_REGISTRATION", etc.
  name              String
  category          CredCategory
  description       String?      @db.Text
  renewalPeriodDays Int? // typical renewal cycle, used for UI hints
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // CEU/CME tracking. When set, the credential surface shows a
  // continuing-education progress bar and reminders. Hours = total CEU
  // required per renewal window; window-months = e.g. 24 for biennial.
  ceuRequirementHours        Int?
  ceuRequirementWindowMonths Int?
  // When true, credentials of this type default to requiring an
  // attached scan (license PDF, board cert, etc.) before flipping the
  // CREDENTIAL_TYPE:* derivation rule to COMPLIANT. Per-credential
  // override possible later via Credential.requiresEvidence (post-launch).
  requiresEvidenceByDefault  Boolean @default(false)

  credentials Credential[]

  @@index([category, sortOrder])
}

// Evidence for CREDENTIAL:* requirements. Append-only at the application
// layer — mutations go through appendEventAndApply() per ADR-0001.
// Status (ACTIVE / EXPIRING_SOON / EXPIRED / ARCHIVED) is derived at
// render time from (retiredAt, expiryDate); not stored.
model Credential {
  id               String    @id @default(cuid())
  practiceId       String
  holderId         String? // PracticeUser.id — null = practice-level credential
  credentialTypeId String
  title            String // free text ("Jane Smith · AZ MD License")
  licenseNumber    String?
  issuingBody      String?
  issueDate        DateTime?
  expiryDate       DateTime?
  notes            String?   @db.Text
  retiredAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  practice       Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  // Audit #21 / Credentials IM-10: tighten cascade contract.
  // MEMBER_REMOVED is a soft-delete (sets PracticeUser.removedAt), so
  // SetNull never actually fires here — the FK only fires on a hard
  // delete. Restrict makes that explicit: a future hard-delete of a
  // PracticeUser must be preceded by an explicit credential-handover
  // (holder reassign) or retirement (Credential.retiredAt) event,
  // rather than silently orphaning the credential's audit trail.
  holder         PracticeUser?  @relation(fields: [holderId], references: [id], onDelete: Restrict)
  credentialType CredentialType @relation(fields: [credentialTypeId], references: [id])

  ceuActivities  CeuActivity[]
  reminderConfig CredentialReminderConfig?

  @@index([practiceId, retiredAt])
  @@index([practiceId, expiryDate])
  @@index([practiceId, holderId])
  // Audit #21 IM-5: idempotent bulk re-upload. Postgres treats NULLs as
  // distinct in unique constraints by default, so this is functionally a
  // partial unique index across non-null licenseNumber rows — exactly
  // what we want. Two staff sharing a null-license credential of the
  // same type don't collide here; their dedup runs in app code via
  // (practice, type, holder, title) instead.
  @@unique([practiceId, credentialTypeId, holderId, licenseNumber])
}

// =====================================================================
// CEU / CME tracking + renewal reminders
// =====================================================================

// One row per continuing-education activity logged against a credential.
// Counts toward CredentialType.ceuRequirementHours within the renewal
// window. Append-only at the application layer; mutations go through
// appendEventAndApply per ADR-0001.
model CeuActivity {
  id           String      @id @default(cuid())
  practiceId   String
  credentialId String
  activityName String
  provider     String?
  activityDate DateTime
  hoursAwarded Float
  category     String?     // free-text (e.g. "Pharmacology", "Ethics") — gated post-launch
  certificateEvidenceId String? // optional FK to Evidence (PR #139)
  notes        String?     @db.Text
  retiredAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  practice            Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  credential          Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  certificateEvidence Evidence?  @relation(fields: [certificateEvidenceId], references: [id], onDelete: SetNull)

  @@index([practiceId, credentialId, activityDate])
  @@index([credentialId, retiredAt])
}

// Per-credential opt-in renewal reminder schedule. Default schedule
// (90/60/30/7 days before expiry) is applied to all expiring credentials
// unless an explicit row overrides it. NotificationType.CREDENTIAL_RENEWAL_DUE
// fires for each milestone day in the schedule.
model CredentialReminderConfig {
  id           String   @id @default(cuid())
  practiceId   String
  credentialId String   @unique
  enabled      Boolean  @default(true)
  // JSON-encoded list of days-before-expiry, e.g. [90, 60, 30, 7].
  // Stored as Int[] for queryability.
  milestoneDays Int[]   @default([90, 60, 30, 7])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice   Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([practiceId])
}

// ────────────────────────────────────────────────────────────────────────────
// Vendors — BAA tracking for HIPAA §164.308(b)(1) / HIPAA_BAA
// ────────────────────────────────────────────────────────────────────────────

// Evidence for BAA_EXECUTED. Append-only at the application layer —
// mutations go through appendEventAndApply() per ADR-0001. Removing a
// vendor sets retiredAt. Editing name/service/processesPhi goes through
// VENDOR_UPSERTED (same event as create); BAA signing is its own event.
model Vendor {
  id            String    @id @default(cuid())
  practiceId    String
  name          String
  type          String? // "EHR" | "Billing" | "IT" | "Cloud" | "Other" — free-text for flexibility
  service       String?   @db.Text // what the vendor provides ("billing clearinghouse")
  contact       String? // primary contact person
  email         String?
  notes         String?   @db.Text
  processesPhi  Boolean   @default(false)
  baaDirection  String? // PRACTICE_PROVIDED | VENDOR_PROVIDED | PLATFORM_ACKNOWLEDGMENT
  baaExecutedAt DateTime? // null = no BAA on file
  baaExpiresAt  DateTime? // null = perpetual / no expiry
  retiredAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  baaRequests BaaRequest[]

  @@index([practiceId, retiredAt])
  @@index([practiceId, processesPhi, baaExpiresAt])
}

// BAA (Business Associate Agreement) lifecycle. One row per BAA cycle
// per vendor. v1 launch supports a single active BAA per vendor; future
// version history (replaces / supersedes) is a post-launch enhancement.
model BaaRequest {
  id                       String    @id @default(cuid())
  practiceId               String
  vendorId                 String
  status                   BaaStatus @default(DRAFT)
  // Optional FK to the Evidence row holding the BAA document. Set when
  // the practice uploads the draft via the Evidence subsystem.
  draftEvidenceId          String?   @unique
  // Recipient email at send time (snapshot of vendor.email at that
  // moment, since vendor.email may change later).
  recipientEmail           String?
  // Optional message included in the email body (custom note from the
  // practice to the vendor).
  recipientMessage         String?   @db.Text
  // Timestamps for state transitions.
  draftUploadedAt          DateTime?
  sentAt                   DateTime?
  acknowledgedAt           DateTime?
  executedAt               DateTime?
  rejectedAt               DateTime?
  expiresAt                DateTime?
  // Vendor signature data captured at execution time. Per HHS guidance,
  // text e-signature + IP + user-agent + timestamp is sufficient for
  // HIPAA §164.504(e). DocuSign integration is post-launch.
  vendorSignatureName      String?
  vendorSignatureIp        String?
  vendorSignatureUserAgent String?   @db.Text
  // Optional rejection reason (only set when status=REJECTED).
  rejectionReason          String?   @db.Text
  // Soft retire (e.g., when a newer BAA version supersedes this one).
  retiredAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  practice         Practice             @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  vendor           Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  draftEvidence    Evidence?            @relation(fields: [draftEvidenceId], references: [id], onDelete: SetNull)
  acceptanceTokens BaaAcceptanceToken[]

  @@index([practiceId, status])
  @@index([practiceId, vendorId, retiredAt])
  @@index([vendorId, status])
}

// Token-protected accept link for the public vendor-accept page. One
// active token per BaaRequest at any given time; resending the BAA
// invalidates prior tokens (sets `revokedAt`).
model BaaAcceptanceToken {
  id           String    @id @default(cuid())
  practiceId   String
  baaRequestId String
  token        String    @unique
  expiresAt    DateTime
  consumedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  practice   Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  baaRequest BaaRequest @relation(fields: [baaRequestId], references: [id], onDelete: Cascade)

  @@index([baaRequestId, revokedAt, consumedAt])
  @@index([expiresAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Training — courses + quiz + completions (ported from v1, minus AI/BYOV)
// ────────────────────────────────────────────────────────────────────────────

// Reference data. Seeded from scripts/seed-training.ts; read-only for practices.
model TrainingCourse {
  id              String   @id @default(cuid())
  code            String   @unique // "HIPAA_BASICS" — used in evidence type TRAINING:<code>
  title           String
  description     String?  @db.Text
  type            String // "HIPAA" | "OSHA" | etc. — display grouping
  lessonContent   String   @db.Text
  durationMinutes Int?
  passingScore    Int      @default(80)
  isRequired      Boolean  @default(false)
  roles           String[] @default([])
  version         Int      @default(1)
  sortOrder       Int      @default(0)
  // Phase 4 PR 6 (BYOV) — optional video lesson. videoUrl stores the
  // Evidence.id (entityType=TRAINING_VIDEO); the player resolves it via
  // /api/evidence/<id>/download for a fresh signed GCS URL per request.
  // videoDurationSec drives the 80% watch-gate before the quiz unlocks.
  videoUrl         String?
  videoDurationSec Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quizQuestions QuizQuestion[]
  completions   TrainingCompletion[]
  assignments   TrainingAssignment[]
  policyPrereqs PolicyTrainingPrereq[]
  videoProgress VideoProgress[]

  @@index([type, sortOrder])
  @@index([isRequired])
}

model QuizQuestion {
  id           String   @id @default(cuid())
  courseId     String
  question     String   @db.Text
  options      String[]
  correctIndex Int
  explanation  String?  @db.Text
  order        Int

  course TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, order])
}

// Evidence for TRAINING:* requirements. Append-only at the application layer —
// mutations go through appendEventAndApply() per ADR-0001. Retaking a course
// creates a new row; derivation picks the latest passed-and-unexpired row per
// (userId, courseId).
model TrainingCompletion {
  id             String   @id @default(cuid())
  practiceId     String
  userId         String // identity User.id (practiceId + userId → PracticeUser)
  courseId       String
  courseVersion  Int
  score          Int // 0–100
  passed         Boolean
  completedAt    DateTime @default(now())
  expiresAt      DateTime // completedAt + 365 days at write time
  certificateUrl String?

  practice Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  course   TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practiceId, userId, courseId])
  @@index([practiceId, courseId, passed, expiresAt])
}

// Phase 4 PR 6 (BYOV) — per-(practice, user, course) progress tracker for
// video lessons. Append-only at the application layer: every
// TRAINING_VIDEO_WATCHED event MAX-merges into watchedSeconds so reports
// arriving out of order or after a rewind never decrement progress.
// userId follows the Phase 4 convention (identity User.id, no FK).
model VideoProgress {
  id             String   @id @default(cuid())
  practiceId     String
  userId         String   // identity User.id
  courseId       String
  watchedSeconds Int      @default(0)
  lastWatchedAt  DateTime @default(now())

  practice Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  course   TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId, courseId])
  @@index([practiceId, courseId])
}

// ────────────────────────────────────────────────────────────────────────────
// Training assignment / scheduling layer (Phase 4)
// ────────────────────────────────────────────────────────────────────────────

// An assignment is a directive: "this user (or this role) must complete this
// course by this date." Resolves at read-time against TrainingCompletion to
// compute status. Soft-revoked via revokedAt (audit-trail preserved).
model TrainingAssignment {
  id                  String    @id @default(cuid())
  practiceId          String
  courseId            String
  // Exactly one of assignedToUserId / assignedToRole / assignedToCategory is
  // non-null. Enforced at the action layer + by the projection's Zod refine.
  assignedToUserId    String?   // when set, single-user assignment
  assignedToRole      String?   // OWNER|ADMIN|STAFF|VIEWER — role-wide
  assignedToCategory  String?   // CLINICAL|ADMINISTRATIVE|MANAGEMENT|OTHER
  dueDate             DateTime?
  requiredFlag        Boolean   @default(true)
  createdByUserId     String
  createdAt           DateTime  @default(now())
  revokedAt           DateTime?
  revokedByUserId     String?
  revokedReason       String?

  practice  Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  course    TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Restrict)
  exclusions AssignmentExclusion[]

  @@index([practiceId, revokedAt])
  @@index([practiceId, courseId, revokedAt])
  @@index([practiceId, assignedToUserId, revokedAt])
}

model AssignmentExclusion {
  id              String   @id @default(cuid())
  assignmentId    String
  userId          String   // identity User.id
  reason          String
  excludedAt      DateTime @default(now())
  excludedByUserId String

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([userId])
}

model PolicyTrainingPrereq {
  id                String         @id @default(cuid())
  practicePolicyId  String
  trainingCourseId  String

  practicePolicy   PracticePolicy   @relation(fields: [practicePolicyId], references: [id], onDelete: Cascade)
  trainingCourse   TrainingCourse   @relation(fields: [trainingCourseId], references: [id], onDelete: Restrict)

  @@unique([practicePolicyId, trainingCourseId])
  @@index([trainingCourseId])
}

// ────────────────────────────────────────────────────────────────────────────
// Event sourcing core (ADR-0001)
// ────────────────────────────────────────────────────────────────────────────

// EventLog is the source of truth for all compliance-relevant state changes.
// Append-only — no UPDATE, no DELETE in application code. Enforced by lint
// rule (`no-direct-projection-mutation`) + code review. Postgres-side enforcement
// will be added in a follow-up migration after the pattern stabilizes.
model EventLog {
  id             String   @id @default(cuid())
  practiceId     String
  actorUserId    String? // null for system-generated events (cron, webhook)
  type           String // EventType enum (TS-side); kept as String here for forward-compat
  schemaVersion  Int      @default(1)
  payload        Json // typed by Zod schema per (type, schemaVersion)
  idempotencyKey String?  @unique // dedup for retried webhooks/cron
  createdAt      DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  actor    User?    @relation("EventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([practiceId, createdAt])
  @@index([practiceId, type, createdAt])
  @@index([type, createdAt])
}

// =====================================================================
// DEA Controlled Substances Act recordkeeping (21 CFR Parts 1304, 1311)
// =====================================================================

// A point-in-time inventory snapshot. Required biennially per 21 CFR
// §1304.11; many practices conduct monthly perpetual inventories on top.
// Has many DeaInventoryItem children (one per drug counted).
model DeaInventory {
  id              String              @id @default(cuid())
  practiceId      String
  asOfDate        DateTime
  conductedByUserId String
  witnessUserId   String?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  practice        Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  items           DeaInventoryItem[]

  @@index([practiceId, asOfDate])
}

// One drug counted in an inventory. Multiple per inventory.
model DeaInventoryItem {
  id          String       @id @default(cuid())
  inventoryId String
  drugName    String
  ndc         String?
  schedule    DeaSchedule
  strength    String?
  quantity    Int
  unit        String       @default("tablets")
  createdAt   DateTime     @default(now())
  inventory   DeaInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
}

// Receipt of a controlled-substance order (Form 222 paper trail or CSOS
// electronic order). One row per drug received. Multi-drug Form 222
// orders (up to 10 line items per federal form) share an `orderBatchId`
// so the Phase C OrdersTab UI + downstream PDF can group line items
// back into a single Form 222 view.
model DeaOrderRecord {
  id                  String      @id @default(cuid())
  practiceId          String
  orderBatchId        String?
  orderedByUserId     String
  supplierName        String
  supplierDeaNumber   String?
  orderedAt           DateTime
  receivedAt          DateTime?
  form222Number       String?
  drugName            String
  ndc                 String?
  schedule            DeaSchedule
  strength            String?
  quantity            Int
  unit                String      @default("tablets")
  notes               String?     @db.Text
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  practice            Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, orderedAt])
  @@index([orderBatchId])
}

// Disposal of controlled substances to a DEA-registered reverse
// distributor (or other authorized disposal method). One row per drug.
// Multi-drug disposals (one reverse-distributor pickup of several
// drugs) share a `disposalBatchId` so Form 41 PDF generation can render
// all the surrendered drugs on one filing.
model DeaDisposalRecord {
  id                          String      @id @default(cuid())
  practiceId                  String
  disposalBatchId             String?
  disposedByUserId            String
  witnessUserId               String?
  reverseDistributorName      String
  reverseDistributorDeaNumber String?
  disposalDate                DateTime
  disposalMethod              String      @default("REVERSE_DISTRIBUTOR") // REVERSE_DISTRIBUTOR | DEA_TAKE_BACK | DEA_DESTRUCTION | OTHER
  drugName                    String
  ndc                         String?
  schedule                    DeaSchedule
  strength                    String?
  quantity                    Int
  unit                        String      @default("tablets")
  form41Filed                 Boolean     @default(false)
  notes                       String?     @db.Text
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
  practice                    Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, disposalDate])
  @@index([disposalBatchId])
}

// Theft or loss of controlled substances. Federal: Form 106 must be
// filed with DEA Field Division within 1 business day of discovery.
// One row per drug; multi-drug events (a single break-in or shipment
// loss involving multiple drugs) share a `reportBatchId` so the Form
// 106 PDF can render the entire event as one filing. `incidentId` is
// a hard FK to the broader Incident record (set-null on incident
// delete so the regulatory record survives).
model DeaTheftLossReport {
  id                       String      @id @default(cuid())
  practiceId               String
  reportBatchId            String?
  incidentId               String?
  reportedByUserId         String
  discoveredAt             DateTime
  reportedAt               DateTime    @default(now())
  lossType                 String      // THEFT | LOSS | IN_TRANSIT_LOSS | DESTRUCTION_DURING_THEFT
  drugName                 String
  ndc                      String?
  schedule                 DeaSchedule
  strength                 String?
  quantityLost             Int
  unit                     String      @default("tablets")
  methodOfDiscovery        String?     @db.Text
  lawEnforcementNotified   Boolean     @default(false)
  lawEnforcementAgency     String?
  lawEnforcementCaseNumber String?
  deaNotifiedAt            DateTime?
  form106SubmittedAt       DateTime?
  notes                    String?     @db.Text
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  practice                 Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  incident                 Incident?   @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([practiceId, discoveredAt])
  @@index([reportBatchId])
  @@index([incidentId])
}

// ────────────────────────────────────────────────────────────────────────────
// Regulations × Operations matrix (ADR-0002 + ADR-0004)
// ────────────────────────────────────────────────────────────────────────────

// A regulatory framework — HIPAA, OSHA, OIG, etc. Adding a new one is an INSERT.
model RegulatoryFramework {
  id              String    @id @default(cuid())
  code            String    @unique // "HIPAA", "OSHA", "OIG", "OSHA_WPV", ...
  name            String
  shortName       String?
  description     String    @db.Text
  citation        String? // "45 CFR Parts 160, 162, 164"
  jurisdiction    String    @default("federal") // "federal" | "state-XX"
  effectiveAt     DateTime?
  supersededAt    DateTime?
  weightDefault   Float     @default(0) // share of overall compliance score
  scoringStrategy String    @default("STANDARD_CHECKLIST") // pluggable per ADR-0004
  iconKey         String? // lucide icon name
  colorKey        String? // design-system color token
  sortOrder       Int       @default(0)
  metadata        Json? // framework-specific extras
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  requirements       RegulatoryRequirement[]
  practiceFrameworks PracticeFramework[]

  @@index([jurisdiction])
  @@index([sortOrder])
}

// Per-practice activation of a framework + computed status. Created lazily
// when a practice's compliance profile activates the framework.
model PracticeFramework {
  id           String    @id @default(cuid())
  practiceId   String
  frameworkId  String
  enabled      Boolean   @default(true)
  enabledAt    DateTime  @default(now())
  disabledAt   DateTime?
  // Cached score (regenerated by event handlers; not source of truth)
  scoreCache   Float?
  scoreLabel   String? // "Compliant" | "Good" | "Needs Work" | "At Risk"
  lastScoredAt DateTime?

  practice  Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  framework RegulatoryFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([practiceId, frameworkId])
  @@index([practiceId, enabled])
}

// One requirement = one row that needs evidence to satisfy.
model RegulatoryRequirement {
  id                    String   @id @default(cuid())
  frameworkId           String
  code                  String // "HIPAA_PRIVACY_NPP", "OSHA_BBP_EXPOSURE_CONTROL"
  title                 String
  description           String   @db.Text
  citation              String?
  severity              String   @default("STANDARD") // STANDARD | CRITICAL | OPTIONAL
  isOptional            Boolean  @default(false)
  // Which states this requirement applies to. Empty array = all jurisdictions.
  jurisdictionFilter    String[] @default([])
  // Which evidence types satisfy this requirement.
  acceptedEvidenceTypes String[] @default([]) // EvidenceType.code values
  weight                Float    @default(1) // relative weight within framework
  sortOrder             Int      @default(0)
  metadata              Json? // framework-specific extras (e.g. DEA Schedule, OSHA recordable)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  framework       RegulatoryFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  complianceItems ComplianceItem[]

  @@unique([frameworkId, code])
  @@index([frameworkId, sortOrder])
}

// The kinds of evidence a practice can produce. Maps each to the "My Programs"
// page that handles producing it.
model EvidenceType {
  id           String  @id @default(cuid())
  code         String  @unique // "POLICY", "TRAINING", "INCIDENT_LOG", "ATTESTATION", "CREDENTIAL", "BAA", "SRA_ANSWER", "DESTRUCTION_LOG", "DRILL_LOG", "INSPECTION"
  name         String
  description  String? @db.Text
  programRoute String // Next.js route, e.g. "/programs/policies"
  iconKey      String?
  sortOrder    Int     @default(0)

  @@index([sortOrder])
}

// Per-practice, per-requirement compliance state. Derived from events, but
// projected here for fast reads. Replaces v1's PracticePolicy-with-prefixed-titles
// and per-module checklist tables.
model ComplianceItem {
  id                String    @id @default(cuid())
  practiceId        String
  requirementId     String
  status            String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLIANT | GAP | NOT_APPLICABLE
  // Optional per-item override of the framework-computed status (admin manual override)
  overrideStatus    String?
  overrideReason    String?   @db.Text
  overrideAt        DateTime?
  overrideByUserId  String?
  // Evidence pointers — denormalized for read speed; primary truth is EventLog
  evidenceCount     Int       @default(0)
  lastEvidenceAt    DateTime?
  // Cached scoring contribution
  contributionCache Float?
  lastUpdatedAt     DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  practice    Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  requirement RegulatoryRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([practiceId, requirementId])
  @@index([practiceId, status])
  @@index([practiceId, lastUpdatedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Compliance score snapshots (replayable from events; cached for trends)
// ────────────────────────────────────────────────────────────────────────────

// Per-practice score history. Each row = one point on the trend graph.
model ComplianceScoreSnapshot {
  id                 String   @id @default(cuid())
  practiceId         String
  snapshotAt         DateTime @default(now())
  overallScore       Float
  overallLabel       String // "Compliant" | "Good" | "Needs Work" | "At Risk"
  // Per-framework breakdown stored as JSON for flexibility
  frameworkBreakdown Json
  // Why this snapshot was created (event-driven, daily cron, manual recompute)
  trigger            String   @default("EVENT")

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, snapshotAt])
}

// ────────────────────────────────────────────────────────────────────────────
// LLM observability (ADR-0003)
// ────────────────────────────────────────────────────────────────────────────

model LlmCall {
  id            String   @id @default(cuid())
  practiceId    String? // nullable for system-level calls (e.g. regulatory analyzer)
  actorUserId   String?
  promptId      String // key into the prompt registry
  promptVersion Int
  model         String
  inputHash     String // sha256 of the redacted input
  inputTokens   Int?
  outputTokens  Int?
  latencyMs     Int
  costUsd       Decimal? @db.Decimal(10, 6)
  success       Boolean
  errorCode     String?
  containsPHI   Boolean  @default(false) // true only when allowPHI=true was passed
  createdAt     DateTime @default(now())

  practice Practice? @relation(fields: [practiceId], references: [id], onDelete: SetNull)

  @@index([practiceId, createdAt])
  @@index([promptId, promptVersion, createdAt])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Waitlist (carried over from v1 marketing — keeps signups during build)
// ────────────────────────────────────────────────────────────────────────────

model Waitlist {
  id           String    @id @default(cuid())
  email        String    @unique
  source       String    @default("marketing") // "marketing", "marketing:AZ", etc.
  practiceName String?
  state        String?
  notes        String?   @db.Text
  invited      Boolean   @default(false)
  invitedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([invited, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Compliance Track — auto-generated onramp
// ────────────────────────────────────────────────────────────────────────────
//
// Each practice gets a single "track" of dated milestones the first time
// PRACTICE_PROFILE_UPDATED fires. The template is keyed by the practice's
// specialtyCategory so a behavioral-health practice doesn't see CLIA/DEA
// tasks. Per docs/specs/v1-ideas-survey.md §1.2.

model PracticeTrack {
  practiceId   String    @id
  templateCode String // GENERAL_PRIMARY_CARE | DENTAL | BEHAVIORAL | GENERIC
  generatedAt  DateTime  @default(now())
  // Set when ALL tasks have completedAt non-null. Recomputed on each
  // task flip; nullable so re-opening a task can clear it.
  completedAt  DateTime?

  practice Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  tasks    PracticeTrackTask[]
}

model PracticeTrackTask {
  id                String    @id @default(cuid())
  practiceId        String
  weekTarget        Int // 1, 2, 4, 8, 12 — target week from track generation
  sortOrder         Int       @default(0)
  title             String
  description       String    @db.Text
  // Route the user clicks to "do" the task (e.g. /programs/staff for the
  // designate-officer tasks).
  href              String
  // Optional auto-completion: if set, the task auto-completes when the
  // matching ComplianceItem (by RegulatoryRequirement.code) flips to
  // COMPLIANT. Hooked into rederiveRequirementStatus.
  requirementCode   String?
  completedAt       DateTime?
  completedByUserId String?
  createdAt         DateTime  @default(now())

  practiceTrack PracticeTrack @relation(fields: [practiceId], references: [practiceId], onDelete: Cascade)

  @@index([practiceId, weekTarget, sortOrder])
  @@index([practiceId, completedAt])
  @@index([practiceId, requirementCode])
}

// ────────────────────────────────────────────────────────────────────────────
// Document retention — destruction log per HIPAA + state retention rules
// ────────────────────────────────────────────────────────────────────────────
//
// Each row = one destruction event documented for audit defensibility.
// Adopting a regular destruction cadence is the practice's evidence that
// retention policies are followed (vs. theoretical-only).

model DestructionLog {
  id                String   @id @default(cuid())
  practiceId        String
  // What was destroyed.
  documentType      String // MEDICAL_RECORDS | BILLING | HR | EMAIL_BACKUPS | OTHER
  description       String   @db.Text // Free-text describing scope (date range, patient cohort, etc.)
  volumeEstimate    String? // "12 boxes" / "300 GB" / "47 patient charts"
  // How.
  method            String // SHREDDING | SECURE_WIPE | DEIDENTIFICATION | INCINERATION | OTHER
  // Who.
  performedByUserId String
  witnessedByUserId String?
  // Vendor-issued certificate of destruction URL/path (if external vendor).
  certificateUrl    String?
  // When the destruction happened (may be backdated).
  destroyedAt       DateTime
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, destroyedAt])
  @@index([practiceId, documentType])
}

// ────────────────────────────────────────────────────────────────────────────
// Technology asset inventory — HIPAA Security Rule §164.310 + .312
// ────────────────────────────────────────────────────────────────────────────
//
// Each row = one piece of tech the practice uses. Used by the SRA to
// answer "what systems hold or transmit ePHI?" — required for a real
// risk analysis.

model TechAsset {
  id           String    @id @default(cuid())
  practiceId   String
  name         String
  // Asset class. Free-form for flexibility but UI offers a fixed set.
  assetType    String // SERVER | LAPTOP | DESKTOP | MOBILE | EMR | NETWORK_DEVICE | CLOUD_SERVICE | OTHER
  processesPhi Boolean   @default(false)
  // Encryption posture for at-rest data on this asset.
  encryption   String // FULL_DISK | FIELD_LEVEL | NONE | UNKNOWN
  vendor       String?
  location     String? // physical location or hosting region
  ownerUserId  String? // staff member responsible
  notes        String?   @db.Text
  retiredAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, retiredAt])
  @@index([practiceId, processesPhi])
}

// ────────────────────────────────────────────────────────────────────────────
// Audit Prep — guided pre-audit workflow per docs/specs/v1-ideas-survey.md §1.1
// ────────────────────────────────────────────────────────────────────────────

enum AuditPrepMode {
  HHS_OCR_HIPAA
  OSHA
  CMS
  DEA
  // State pharmacy board allergen-extract compounding inspections
  // (USP 797 §21). Added 2026-04-30 — closes audit #21 IM-3.
  ALLERGY
}

enum AuditPrepStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum AuditPrepStepStatus {
  PENDING
  COMPLETE
  NOT_APPLICABLE
}

// One audit-prep session per "I just got the audit letter" moment. Mode
// gates which protocols apply; status walks DRAFT → IN_PROGRESS (first
// step touched) → COMPLETED (packet generated).
model AuditPrepSession {
  id                String          @id @default(cuid())
  practiceId        String
  mode              AuditPrepMode
  status            AuditPrepStatus @default(DRAFT)
  startedByUserId   String
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  packetGeneratedAt DateTime?

  practice Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  steps    AuditPrepStep[]

  @@index([practiceId, startedAt])
  @@index([practiceId, status])
}

// One row per protocol within a session. Generated up-front when the
// session opens (one INSERT per ProtocolDef in PROTOCOLS_BY_MODE[mode]).
// `evidenceJson` snapshots the live evidence at completion time so the
// PDF stays stable even if underlying tables change later.
model AuditPrepStep {
  id                String              @id @default(cuid())
  sessionId         String
  code              String // matches ProtocolDef.code
  title             String // snapshot at session creation
  status            AuditPrepStepStatus @default(PENDING)
  evidenceJson      Json? // structured evidence captured at completion
  notes             String?             @db.Text
  completedAt       DateTime?
  completedByUserId String?
  createdAt         DateTime            @default(now())

  session AuditPrepSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, code])
  @@index([sessionId, status])
}

// ────────────────────────────────────────────────────────────────────────────
// Policy template catalog (2026-04-24)
// ────────────────────────────────────────────────────────────────────────────
//
// Browseable catalog of 130+ policy templates ported from v1 (HIPAA: 75,
// OSHA: 38, GENERAL: 15, DEA: 2). PracticePolicy.policyCode references a
// template's code; the existing 9-code "core" set in policies.ts still
// drives derivation. Templates beyond the core 9 are adoptable but
// optional — they expand the practice's policy library without
// changing module compliance scoring.
//
// Adopting a template creates a PracticePolicy whose `content` is
// initialized from the template's bodyMarkdown. Subsequent edits live
// on the PracticePolicy row only — the template stays canonical for
// new adoptions.

model PolicyTemplate {
  id              String   @id @default(cuid())
  code            String   @unique // e.g. HIPAA_RISK_ANALYSIS_POLICY
  title           String
  framework       String // HIPAA | OSHA | GENERAL | DEA — single string,
  // matches RegulatoryFramework.code where applicable.
  description     String   @db.Text
  bodyMarkdown    String   @db.Text
  // State filter (e.g. "MA" for state-specific templates) and specialty
  // filter (e.g. "ALLERGY_IMMUNOLOGY"). Both null = universal template.
  stateFilter     String?
  specialtyFilter String?
  sortOrder       Int      @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([framework, sortOrder])
  @@index([stateFilter])
}

// ────────────────────────────────────────────────────────────────────────────
// Cybersecurity emphasis (2026-04-23) — Phishing drills + backup verification
// ────────────────────────────────────────────────────────────────────────────
//
// These complement the existing TechAsset model (encryption posture) and the
// new mfaEnrolledAt field on PracticeUser. Together they feed the
// /programs/cybersecurity readiness score and four new HIPAA requirements:
//   - HIPAA_CYBER_TRAINING_COMPLETE   (workforce coverage of 4 cyber courses)
//   - HIPAA_MFA_COVERAGE_GE_80        (≥80% of users with mfaEnrolledAt set)
//   - HIPAA_PHISHING_DRILL_RECENT     (≥1 PhishingDrill in last 6 months)
//   - HIPAA_BACKUP_VERIFIED_RECENT    (≥1 successful BackupVerification in 90 days)

// One row per simulated phishing campaign run for the practice. Cyber
// insurance carriers and HIPAA Security Rule §164.308(a)(5) treat regular
// phishing simulation as a baseline workforce-awareness control.
model PhishingDrill {
  id              String   @id @default(cuid())
  practiceId      String
  conductedAt     DateTime
  vendor          String? // e.g., "KnowBe4", "Hoxhunt", "Microsoft Attack Simulator", or "Internal"
  totalRecipients Int
  clickedCount    Int      @default(0)
  reportedCount   Int      @default(0)
  attachmentUrl   String? // optional GCS link to vendor PDF report
  loggedByUserId  String
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, conductedAt])
}

// One row per restore-test of a backup. The HHS OCR Ransomware Fact Sheet
// + the Security Rule contingency plan standards both treat untested
// backups as effectively no backups.
model BackupVerification {
  id                 String   @id @default(cuid())
  practiceId         String
  verifiedAt         DateTime
  scope              String // free-form: "EHR", "Files", "Email", "Imaging", etc.
  success            Boolean
  restoreTimeMinutes Int? // optional — measured RTO from the test
  loggedByUserId     String
  notes              String?  @db.Text
  createdAt          DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, verifiedAt])
  @@index([practiceId, success])
}

// ────────────────────────────────────────────────────────────────────────────
// Onboarding drip emails — Phase E (docs/specs/onboarding-flow.md § Screen 9)
// ────────────────────────────────────────────────────────────────────────────
//
// One row per (practice, day) drip email sent. The cron runner uses the
// (practiceId, day) unique constraint as the idempotency guard — second +
// later runs for the same day are no-ops. day ∈ {1, 3, 5, 7, 10}, measured
// from trial start (trialEndsAt - 7 days).
model OnboardingDripSent {
  id             String   @id @default(cuid())
  practiceId     String
  day            Int // 1 | 3 | 5 | 7 | 10
  recipientEmail String
  sentAt         DateTime @default(now())
  emailDelivered Boolean
  emailReason    String? // reason if delivery failed (Resend error, etc.)

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, day])
  @@index([sentAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Allergy / USP 797 §21 — allergen extract compounding compliance
// (docs/plans/2026-04-27-allergy-module.md)
// ────────────────────────────────────────────────────────────────────────────

enum AllergyQuizCategory {
  ASEPTIC_TECHNIQUE
  CALCULATIONS
  LABELING
  BEYOND_USE_DATES
  DOCUMENTATION
  EMERGENCY_RESPONSE
  STORAGE_STABILITY
  REGULATIONS
}

enum AllergyCheckType {
  EMERGENCY_KIT
  REFRIGERATOR_TEMP
  SKIN_TEST_SUPPLIES
}

/// Per-staff, per-year record of all three USP 797 §21 competency
/// components. Projected from ALLERGY_QUIZ_COMPLETED +
/// ALLERGY_FINGERTIP_TEST_PASSED + ALLERGY_MEDIA_FILL_PASSED events.
/// `isFullyQualified` is recomputed after every projection write.
model AllergyCompetency {
  id                    String    @id @default(cuid())
  practiceId            String
  practiceUserId        String
  year                  Int       // calendar year (e.g. 2026)
  // Component A: written quiz (ALLERGY_QUIZ_COMPLETED with passed=true)
  quizAttemptId         String?   @unique
  quizPassedAt          DateTime?
  // Component B: gloved fingertip + thumb sampling
  // (USP §21: 3 passes required for initial qualification; 1 for annual renewal)
  fingertipPassCount    Int       @default(0)
  fingertipLastPassedAt DateTime?
  fingertipAttestedById String?
  fingertipNotes        String?   @db.Text
  // Component C: media fill test (ALLERGY_MEDIA_FILL_PASSED)
  mediaFillPassedAt     DateTime?
  mediaFillAttestedById String?
  mediaFillNotes        String?   @db.Text
  // Derived
  isFullyQualified      Boolean   @default(false)
  lastCompoundedAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practice           Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceUser       PracticeUser        @relation("AllergyCompetencyHolder", fields: [practiceUserId], references: [id], onDelete: Cascade)
  fingertipAttestor  PracticeUser?       @relation("AllergyFingertipAttestor", fields: [fingertipAttestedById], references: [id], onDelete: SetNull)
  mediaFillAttestor  PracticeUser?       @relation("AllergyMediaFillAttestor", fields: [mediaFillAttestedById], references: [id], onDelete: SetNull)
  passingAttempt     AllergyQuizAttempt? @relation("PassingAttempt", fields: [quizAttemptId], references: [id])

  @@unique([practiceUserId, year])
  @@index([practiceId, year])
  @@index([practiceId, isFullyQualified])
}

/// USP 797 §21 quiz question. Static catalog seeded once via
/// scripts/seed-allergy.ts; not per-practice.
model AllergyQuizQuestion {
  id           String              @id @default(cuid())
  questionText String              @db.Text
  options      Json                // [{id: "a", text: "..."}, {id: "b", text: "..."}]
  correctId    String              // matches the id from options
  explanation  String?             @db.Text
  category     AllergyQuizCategory
  isActive     Boolean             @default(true)
  displayOrder Int                 @default(0)
  createdAt    DateTime            @default(now())

  answers AllergyQuizAnswer[]
}

/// One quiz attempt by a staff member. Result event = ALLERGY_QUIZ_COMPLETED.
model AllergyQuizAttempt {
  id             String    @id @default(cuid())
  practiceId     String
  practiceUserId String
  year           Int
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  score          Int?      // 0-100 percentage
  passed         Boolean?  // true if score >= 80
  totalQuestions Int       @default(0)
  correctAnswers Int       @default(0)

  practice          Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceUser      PracticeUser        @relation("AllergyQuizTaker", fields: [practiceUserId], references: [id], onDelete: Cascade)
  answers           AllergyQuizAnswer[]
  passingCompetency AllergyCompetency?  @relation("PassingAttempt")

  @@index([practiceId, practiceUserId, year])
  @@index([practiceUserId, completedAt])
}

/// Per-question answer record on a quiz attempt.
model AllergyQuizAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  selectedId String
  isCorrect  Boolean

  attempt  AllergyQuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question AllergyQuizQuestion @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

/// Equipment check log. checkType discriminator drives which fields are set.
/// Projected from ALLERGY_EQUIPMENT_CHECK_LOGGED events.
/// Audit #15 (2026-04-30) added typo-correction (UPDATED) + soft-delete
/// (DELETED, sets retiredAt). Reads filter retiredAt IS NULL; the row
/// stays for audit replay.
model AllergyEquipmentCheck {
  id              String           @id @default(cuid())
  practiceId      String
  checkedById     String           // PracticeUser.id
  checkType       AllergyCheckType
  checkedAt       DateTime         @default(now())
  // EMERGENCY_KIT
  epiExpiryDate   DateTime?
  epiLotNumber    String?
  allItemsPresent Boolean?
  itemsReplaced   String?          @db.Text
  // REFRIGERATOR_TEMP
  temperatureC    Float?
  inRange         Boolean?         // acceptable: 2.0–8.0°C
  // shared
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  // Audit #15: soft-delete timestamp. Non-null = retired row (hidden
  // from list reads, preserved for EventLog replay + cross-tenant guard).
  retiredAt       DateTime?

  practice  Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  checkedBy PracticeUser @relation("AllergyCheckPerformedBy", fields: [checkedById], references: [id])

  @@index([practiceId, checkType, checkedAt])
}

/// Anaphylaxis drill log. Annual minimum per practice. Projected from
/// ALLERGY_DRILL_LOGGED events. Audit #15 (2026-04-30) added
/// typo-correction (UPDATED) + soft-delete (DELETED, sets retiredAt).
/// Reads filter retiredAt IS NULL; the row stays for audit replay.
/// `participantIds` stores PracticeUser.id values without FK enforcement;
/// resolve names with a separate findMany. Acceptable for typical small
/// staff sizes; revisit with a join table if drills routinely have 20+
/// participants or "drills participated in by user X" becomes a hot query.
///
/// TODO(audit #21 IM-2, future PR): convert `participantIds: String[]` to
/// a proper join table (`AllergyDrillParticipant { drillId, practiceUserId,
/// @@id }`) so FK integrity is enforced at the DB layer and "drills for
/// user X" becomes an indexed lookup. The action layer currently validates
/// FK integrity via `assertParticipantsActiveMembers` in actions.ts as the
/// interim guard, plus the DrillTab UI surfaces "User no longer at practice"
/// for legacy ids that no longer resolve to a current member.
model AllergyDrill {
  id                String   @id @default(cuid())
  practiceId        String
  conductedById     String   // PracticeUser.id
  conductedAt       DateTime
  scenario          String   @db.Text
  participantIds    String[]            // PracticeUser.id[]
  durationMinutes   Int?
  observations      String?  @db.Text
  correctiveActions String?  @db.Text
  nextDrillDue      DateTime?
  createdAt         DateTime @default(now())
  // Audit #15: soft-delete timestamp. Non-null = retired row (hidden
  // from list reads, preserved for EventLog replay + cross-tenant guard).
  retiredAt         DateTime?

  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  conductedBy PracticeUser @relation("AllergyDrillLedBy", fields: [conductedById], references: [id])

  @@index([practiceId, conductedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// MACRA / MIPS — activity log for the four MIPS performance categories
// (docs/plans/2026-04-28-phase-1-derivation-completeness.md PR 6)
// ────────────────────────────────────────────────────────────────────────────

/// MACRA / MIPS activity log entry. Projected from MACRA_ACTIVITY_LOGGED events.
/// activityType partitions the four MIPS performance categories so the
/// derivation rules can count by category for the attestationYear.
/// Append-only: rows are never mutated after creation.
///
/// loggedByUserId stores User.id with no FK — matches PhishingDrill.loggedByUserId
/// (line ~1500) and BackupVerification.loggedByUserId (line ~1519). User-id
/// integrity is enforced at the event payload validation layer (Zod min(1)).
/// User deletion is rare; if it happens, this row remains as historical audit
/// data, which is the correct behavior for an append-only log.
model MacraActivityLog {
  id              String   @id @default(cuid())
  practiceId      String
  activityCode    String   // e.g. IA_BMH_9 (Improvement Activity catalog code)
  activityType    String   // QUALITY | IMPROVEMENT | PI | SUBMISSION
  attestationYear Int      // QPP performance year this activity counts toward
  activityName    String
  loggedByUserId  String   // User.id (no FK — see model header)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, attestationYear, activityType])
}

// ────────────────────────────────────────────────────────────────────────────
// AI Concierge — chat thread + messages
// (docs/plans/2026-04-28-phase-2-concierge-section-g.md PR A1)
// ────────────────────────────────────────────────────────────────────────────

/// AI Concierge conversation. Top-level container for a chat session.
/// Projected from CONCIERGE_THREAD_CREATED events. Title may be auto-generated
/// server-side from the first user message after the message lands.
///
/// userId stores User.id with no FK — matches PhishingDrill.loggedByUserId
/// (line ~1500), BackupVerification.loggedByUserId (line ~1519), and
/// MacraActivityLog.loggedByUserId (above). User-id integrity is enforced at
/// the event payload validation layer (Zod min(1)). User deletion is rare;
/// if it happens, threads remain as historical audit data, which is the
/// correct behavior for an append-only conversation log.
///
/// Note: `Practice.deletedAt` (soft-delete) does NOT cascade to threads —
/// soft-deleted practices keep their threads as historical audit data. A hard
/// delete via `practice.delete()` cascades through the FK.
///
/// Append-only at the projection level — only title, lastMessageAt, and
/// archivedAt mutate after creation.
model ConversationThread {
  id            String    @id @default(cuid())
  practiceId    String
  userId        String    // User.id (no FK — see model header)
  title         String?
  createdAt     DateTime  @default(now())
  lastMessageAt DateTime  @default(now())
  archivedAt    DateTime?

  practice Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  // 2-col index: filtering archivedAt IS NULL between practiceId and lastMessageAt
  // would break Postgres's leftmost-prefix sort; planner range-scans + filters
  // the rare archived rows in memory. (userId index dropped — speculative.)
  @@index([practiceId, lastMessageAt])
}

/// Single message in a Concierge thread. Append-only.
/// role distinguishes USER / ASSISTANT / TOOL — TOOL rows store the
/// tool_use input + tool_result output as a serialized JSON `payload`.
/// inputTokens/outputTokens/costUsd/llmCallId are populated on ASSISTANT
/// rows for observability (link back to LlmCall for prompt-cache hit-rate).
model ConversationMessage {
  id           String   @id @default(cuid())
  threadId     String
  role         String   // USER | ASSISTANT | TOOL
  content      String   @db.Text  // human-readable; for TOOL rows: short summary
  payload      Json     // raw structured payload (tool input/output, etc.)
  inputTokens  Int?
  outputTokens Int?
  costUsd      Decimal? @db.Decimal(10, 6)
  llmCallId    String?
  createdAt    DateTime @default(now())

  thread ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// Evidence / file uploads — polymorphic across credentials, vendors,
// incidents, destruction logs, etc.
// (docs/plans/2026-04-27-evidence-ceu-reminders.md)
// ────────────────────────────────────────────────────────────────────────────

enum EvidenceStatus {
  PENDING
  UPLOADED
  DELETED
}

model Evidence {
  id             String         @id @default(cuid())
  practiceId     String
  // Polymorphic association — entityType ∈ {DESTRUCTION_LOG, CREDENTIAL,
  // VENDOR, INCIDENT, TECH_ASSET, TRAINING_COMPLETION, OTHER}
  entityType     String
  entityId       String         // FK to parent (loose; not enforced at DB level)
  uploadedById   String?        // PracticeUser.id who triggered upload (nullable: SetNull on hard-delete)
  gcsKey         String         @unique // path in GCS bucket
  fileName       String         // original filename
  mimeType       String         // application/pdf, image/png, etc.
  fileSizeBytes  Int
  status         EvidenceStatus @default(PENDING) // PENDING → UPLOADED → DELETED
  uploadedAt     DateTime       @default(now())
  confirmedAt    DateTime?
  deletedAt      DateTime?
  notes          String?        @db.Text

  practice   Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  uploadedBy PracticeUser? @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  ceuActivities CeuActivity[]
  baaRequests   BaaRequest[]

  @@index([practiceId, entityType, entityId])
  @@index([practiceId, status])
}
